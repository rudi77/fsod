# Azure OpenAI Konfiguration — kopiere diese Datei nach ".env" und trage deine Werte ein.
# (Die .env wird NICHT eingecheckt — siehe .gitignore)

AZURE_OPENAI_ENDPOINT=https://DEIN-RESSOURCENNAME.openai.azure.com/
AZURE_OPENAI_API_KEY=dein-api-key
AZURE_OPENAI_DEPLOYMENT=dein-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
