# Kopieren nach .env und ausfüllen. Alle Werte sind auch als normale
# Env-Vars setzbar (echte Env-Vars gewinnen gegen .env).

# --- LLM-Provider: exakt der Env-Contract von agentkit (src/llm.rs) ---------
# Variante A: LiteLLM-Proxy (beliebige Upstream-Modelle, empfohlen)
#   docker compose -f litellm/docker-compose.yml up -d
OPENAI_API_KEY=sk-local-bench
OPENAI_MODEL=bench-model
OPENAI_BASE_URL=http://localhost:4000/v1

# Variante B: direkt OpenAI — OPENAI_BASE_URL leer lassen/entfernen,
#   OPENAI_API_KEY=sk-... und OPENAI_MODEL=gpt-4o setzen.

# Variante C: Azure OpenAI — AGENTKIT_PROVIDER=azure und:
#AZURE_OPENAI_ENDPOINT=
#AZURE_OPENAI_API_KEY=
#AZURE_OPENAI_DEPLOYMENT=
#AZURE_OPENAI_API_VERSION=2024-10-21

# auto|azure|openai|demo  (demo = offline, für Plumbing-Tests ohne API-Kosten)
AGENTKIT_PROVIDER=openai

# --- LiteLLM ----------------------------------------------------------------
LITELLM_MASTER_KEY=sk-local-bench
# Upstream-Keys für den Proxy (nur nötig bei Variante A):
#UPSTREAM_OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...

# --- Container-Netzwerk -----------------------------------------------------
# OPENAI_BASE_URL aus Sicht der Task-Container. Leer = automatische
# Umschreibung localhost -> host.docker.internal (Docker Desktop) bzw.
# Docker-Bridge-Gateway (Linux). Bei Custom-Netzwerken: Host-LAN-IP eintragen.
#BENCH_CONTAINER_BASE_URL=

# --- Harness-Knobs ----------------------------------------------------------
AGENTKIT_MAX_STEPS=100
SWEBENCH_LIMIT=25
SWEBENCH_WORKERS=4
TB_CONCURRENT=4
# Sprachen für den Polyglot-Smoke (Task-Präfixe: polyglot_<sprache>_*)
POLYGLOT_LANGS=python rust
# Name in den SWE-bench-Predictions (Default: agentkit-$OPENAI_MODEL)
#BENCH_MODEL_NAME=

# --- Binary-Auslieferung ----------------------------------------------------
# Default: build/agentkit-x86_64-musl wird per upload_file/docker cp in die
# Container kopiert. Für Cloud-Executors ohne Host-Dateizugriff stattdessen
# eine URL (z.B. GitHub-Release-Asset) setzen:
#AGENTKIT_BINARY_URL=
#AGENTKIT_BINARY_PATH=
