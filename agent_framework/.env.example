# Azure OpenAI (wie in den Notebooks) — für agentkit.azure_from_env()
AZURE_OPENAI_ENDPOINT=https://<ressource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<dein-key>
AZURE_OPENAI_DEPLOYMENT=<dein-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# Alternativ Standard-OpenAI — für agentkit.openai_from_env()
# OPENAI_API_KEY=<dein-key>
# OPENAI_MODEL=gpt-4o-mini

# Alternativ ein lokaler OpenAI-kompatibler Server (Ollama, LM Studio, vLLM, llama.cpp):
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5-coder
# (OPENAI_API_KEY kann entfallen — lokale Server verlangen meist keinen.)
